---
import Layout from '../layouts/Layout.astro';

const faqs = [
	{
		q: 'Is StillMotion really free?',
		a: 'Yes. StillMotion is completely free to use, supported by lightweight advertising rather than subscriptions or paywalls.',
	},
	{
		q: 'Are my photos uploaded to a server?',
		a: 'No. Every conversion happens locally in your browser using WebAssembly (ffmpeg.wasm). Your photo is never sent anywhere.',
	},
	{
		q: 'What image formats can I use?',
		a: 'JPG, PNG, WebP, and other formats your browser can natively decode, plus iPhone HEIC/HEIF photos, which are decoded locally via libheif-js.',
	},
	{
		q: 'What video formats can I export to?',
		a: 'MP4 (H.264) and WebM (VP9), both widely supported across social platforms, editors, and devices.',
	},
	{
		q: 'How long can the video be?',
		a: 'Anywhere from 1 to 30 seconds. Your still photo is looped for the entire duration.',
	},
	{
		q: 'Why did the conversion fail or seem stuck?',
		a: 'The first click loads the ffmpeg.wasm engine, which is a few megabytes and can take a moment on a slow connection. Very large source photos can also take longer to encode. If it truly fails, try a smaller image or refresh and try again.',
	},
	{
		q: 'Does this work on mobile?',
		a: 'Yes, StillMotion works in modern mobile browsers, though video encoding is more memory- and CPU-intensive on phones, so very long durations or very large photos may be slower.',
	},
];
---

<Layout
	title="FAQ — StillMotion"
	description="Frequently asked questions about StillMotion, the private browser-based photo-to-video converter."
	canonicalPath="/faq"
>
	<section class="mx-auto max-w-2xl">
		<h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Frequently Asked Questions</h1>

		<div class="mt-8 space-y-6">
			{faqs.map((item) => (
				<div class="rounded-xl p-5" style="background:#FFFFFF; border:1px solid #E8DFC8;">
					<h2 class="text-base font-semibold" style="color:#2B2013;">{item.q}</h2>
					<p class="mt-2 text-sm leading-relaxed" style="color:#5C4F3D;">{item.a}</p>
				</div>
			))}
		</div>
	</section>
</Layout>
