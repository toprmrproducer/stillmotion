---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Privacy Policy — StillMotion"
	description="StillMotion's privacy policy: your photos and videos never leave your browser. No uploads, no server-side processing, no file storage."
	canonicalPath="/privacy"
>
	<section>
		<h1 class="text-3xl sm:text-4xl">Privacy Policy</h1>
		<p class="mt-3 text-[15px]" style="color:#8A7E68;">Last updated: July 2026</p>

		<div class="mt-8 space-y-8">
			<div>
				<h2 class="text-xl" style="color:#221B10;">Your files never leave your device</h2>
				<p class="mt-2 leading-relaxed" style="color:#4A4234;">
					StillMotion processes every photo and video entirely inside your
					browser tab using WebAssembly (ffmpeg.wasm and libheif-js). Your
					image is never uploaded to any server, never transmitted over the
					network, and never stored by us in any form. When you close or
					refresh the tab, everything is discarded.
				</p>
			</div>

			<div>
				<h2 class="text-xl" style="color:#221B10;">Analytics</h2>
				<p class="mt-2 leading-relaxed" style="color:#4A4234;">
					We may use privacy-respecting analytics to understand aggregate
					traffic (e.g. page views, referrers). This does not include the
					content of any file you convert.
				</p>
			</div>

			<div>
				<h2 class="text-xl" style="color:#221B10;">Advertising</h2>
				<p class="mt-2 leading-relaxed" style="color:#4A4234;">
					StillMotion may display ads served by third-party ad networks
					(such as Google AdSense) to keep the tool free. These networks may
					use cookies or similar technologies to serve relevant ads. You can
					control ad personalization through your browser or through Google's
					own ad settings.
				</p>
			</div>

			<div>
				<h2 class="text-xl" style="color:#221B10;">Cookies</h2>
				<p class="mt-2 leading-relaxed" style="color:#4A4234;">
					StillMotion itself does not set cookies to track you. Third-party
					ad or analytics providers embedded on this site may set their own
					cookies subject to their own privacy policies.
				</p>
			</div>

			<div>
				<h2 class="text-xl" style="color:#221B10;">Contact</h2>
				<p class="mt-2 leading-relaxed" style="color:#4A4234;">
					Questions about this policy can be sent via the contact details
					listed on our <a href={`${import.meta.env.BASE_URL}about`} class="font-semibold" style="color:#C9982E;">About page</a>.
				</p>
			</div>
		</div>
	</section>
</Layout>
