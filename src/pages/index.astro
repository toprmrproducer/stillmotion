---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="StillMotion — Turn Any Photo Into a Video Clip"
	description="Turn any photo into a downloadable MP4 or WebM video clip, right in your browser. Add cinematic Ken Burns pan and zoom. No uploads, no server — 100% private, powered by ffmpeg.wasm."
	canonicalPath="/"
>
	<section class="text-center">
		<span
			class="inline-block rounded-full px-4 py-1.5 text-xs font-bold uppercase tracking-wide"
			style="background:#FAF8F3; border:1px solid #EAE4D6; color:#C9982E;"
		>
			Private &middot; Client-side &middot; Free
		</span>
		<h1 class="mt-6 text-4xl sm:text-5xl">
			Turn any photo into a video clip
		</h1>
		<p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed" style="color:#4A4234;">
			Drop in a still photo, choose a duration, add a cinematic Ken Burns
			pan or zoom, and StillMotion renders a real, downloadable MP4 or WebM
			&mdash; entirely inside your browser tab. Nothing you upload is ever
			sent anywhere.
		</p>
	</section>

	<section class="mt-14">
		<div
			class="rounded-2xl p-6 shadow-sm sm:p-8"
			style="background:#FAF8F3; border:1px solid #EAE4D6;"
		>
			<form id="tool-form" class="space-y-8">
				<div>
					<label
						for="image-input"
						class="block text-[15px] font-bold"
						style="color:#221B10;"
					>
						1. Choose an image
					</label>
					<label
						id="drop-zone"
						for="image-input"
						class="mt-3 flex cursor-pointer flex-col items-center justify-center rounded-xl border-2 border-dashed px-6 py-12 text-center transition"
						style="border-color:#EAE4D6; background:#FFFFFF;"
					>
						<svg
							class="h-8 w-8"
							style="color:#C9982E;"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"
							/>
						</svg>
						<span class="mt-3 text-base font-semibold" style="color:#221B10;">
							Click to choose a photo, or drag one here
						</span>
						<span class="mt-1 text-[15px]" style="color:#8A7E68;">
							JPG, PNG, WebP, HEIC/HEIF &mdash; up to your browser's memory limit
						</span>
					</label>
					<input
						id="image-input"
						type="file"
						accept="image/*,.heic,.heif"
						class="hidden"
					/>
					<div id="preview-wrap" class="mt-4 hidden">
						<p class="mb-2 text-xs font-bold uppercase tracking-wide" style="color:#8A7E68;">
							Preview
						</p>
						<img
							id="preview-img"
							alt="Selected image preview"
							class="max-h-64 w-auto rounded-xl"
							style="border:1px solid #EAE4D6; background:#FFFFFF;"
						/>
					</div>
				</div>

				<div class="grid gap-6 sm:grid-cols-2">
					<div>
						<label
							for="duration-input"
							class="block text-[15px] font-bold"
							style="color:#221B10;"
						>
							2. Duration (seconds)
						</label>
						<input
							id="duration-input"
							type="number"
							min="1"
							max="30"
							step="1"
							value="5"
							class="mt-3 block min-h-[44px] w-full rounded-lg px-3.5 py-2.5 text-base outline-none focus:ring-2 focus:ring-[#C9982E]/40"
							style="border:1px solid #EAE4D6; background:#FFFFFF; color:#221B10;"
						/>
						<input
							id="duration-range"
							type="range"
							min="1"
							max="30"
							step="1"
							value="5"
							class="mt-3 w-full accent-[#C9982E]"
						/>
					</div>

					<div>
						<label
							for="format-select"
							class="block text-[15px] font-bold"
							style="color:#221B10;"
						>
							3. Output format
						</label>
						<select
							id="format-select"
							class="mt-3 block min-h-[44px] w-full rounded-lg px-3.5 py-2.5 text-base outline-none focus:ring-2 focus:ring-[#C9982E]/40"
							style="border:1px solid #EAE4D6; background:#FFFFFF; color:#221B10;"
						>
							<option value="mp4">MP4 (H.264)</option>
							<option value="webm">WebM (VP8)</option>
						</select>
						<p class="mt-2 text-xs leading-snug" style="color:#8A7E68;">
							MP4 plays everywhere. WebM exports with the VP8 codec &mdash; the
							in-browser VP9 encoder is unstable, so we don't offer it.
						</p>
					</div>
				</div>

				{/* NICHE FEATURE: Ken Burns motion. Direction (zoom-in / zoom-out /
				    pan-left / pan-right) + the duration control above drive a real
				    animated clip instead of a static frame. Secondary to the core
				    photo-to-video encode, which still works with motion = None. */}
				<div>
					<label
						class="block text-[15px] font-bold"
						style="color:#221B10;"
					>
						4. Ken Burns motion
					</label>
					<p class="mt-1 text-xs leading-snug" style="color:#8A7E68;">
						Give the clip a subtle cinematic drift, rendered frame-by-frame on
						your device over the full duration. A little slower to encode.
					</p>
					<div
						id="motion-grid"
						class="mt-3 grid grid-cols-2 gap-2.5 sm:grid-cols-5"
						role="radiogroup"
						aria-label="Ken Burns motion direction"
					>
						<button type="button" data-motion="none" aria-pressed="true"
							class="motion-opt min-h-[44px] rounded-lg px-3 py-2 text-sm font-semibold transition"
							style="border:1px solid #C9982E; background:#F4EAD3; color:#221B10;">
							None
						</button>
						<button type="button" data-motion="zoom-in" aria-pressed="false"
							class="motion-opt min-h-[44px] rounded-lg px-3 py-2 text-sm font-semibold transition"
							style="border:1px solid #EAE4D6; background:#FFFFFF; color:#4A4234;">
							Zoom in
						</button>
						<button type="button" data-motion="zoom-out" aria-pressed="false"
							class="motion-opt min-h-[44px] rounded-lg px-3 py-2 text-sm font-semibold transition"
							style="border:1px solid #EAE4D6; background:#FFFFFF; color:#4A4234;">
							Zoom out
						</button>
						<button type="button" data-motion="pan-left" aria-pressed="false"
							class="motion-opt min-h-[44px] rounded-lg px-3 py-2 text-sm font-semibold transition"
							style="border:1px solid #EAE4D6; background:#FFFFFF; color:#4A4234;">
							Pan left
						</button>
						<button type="button" data-motion="pan-right" aria-pressed="false"
							class="motion-opt min-h-[44px] rounded-lg px-3 py-2 text-sm font-semibold transition"
							style="border:1px solid #EAE4D6; background:#FFFFFF; color:#4A4234;">
							Pan right
						</button>
					</div>
					<input id="motion-value" type="hidden" value="none" />
				</div>

				<button
					id="generate-btn"
					type="button"
					class="min-h-[48px] w-full rounded-xl px-6 py-3 text-base font-bold text-white transition hover:bg-[#B8860B] disabled:cursor-not-allowed disabled:opacity-50 sm:w-auto"
					style="background:#C9982E;"
				>
					Generate Video
				</button>

				<div id="status-wrap" class="hidden">
					<div class="flex items-center justify-between text-[15px] font-medium">
						<span id="status-text" style="color:#4A4234;">Loading engine&hellip;</span>
						<span id="status-percent" style="color:#8A7E68;"></span>
					</div>
					<div class="mt-2 h-2 w-full overflow-hidden rounded-full" style="background:#EAE4D6;">
						<div
							id="progress-bar"
							class="h-full w-0 rounded-full transition-all duration-150"
							style="background:#C9982E;"
						>
						</div>
					</div>
					<p class="mt-3 text-[15px]" style="color:#4A4234;">
						This can take a moment &mdash; scroll down and play a round of
						Snake while you wait.
					</p>
				</div>

				<div
					id="error-box"
					class="hidden rounded-lg px-4 py-3 text-[15px]"
					style="border:1px solid #E0B4A8; background:#FBEEEB; color:#9A3B2B;"
				>
				</div>

				<div id="result-wrap" class="hidden rounded-xl p-4" style="border:1px solid #EAE4D6; background:#FFFFFF;">
					<p class="text-[15px] font-bold" style="color:#221B10;">Your video is ready.</p>
					<video
						id="result-video"
						controls
						playsinline
						class="mt-3 max-h-80 w-full rounded-lg bg-black"
						style="border:1px solid #EAE4D6;"
					></video>
					<a
						id="download-link"
						href="#"
						class="mt-4 inline-flex min-h-[44px] items-center justify-center rounded-xl px-5 py-2.5 text-[15px] font-bold text-white transition hover:bg-[#B8860B]"
						style="background:#C9982E;"
					>
						Download video
					</a>
				</div>
			</form>
		</div>
	</section>

	<section class="mt-24">
		<h2 class="text-2xl">How it works</h2>
		<div class="mt-7 grid gap-6 sm:grid-cols-3">
			<div class="rounded-xl p-5 shadow-sm" style="background:#FAF8F3; border:1px solid #EAE4D6;">
				<div
					class="flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold"
					style="background:#F4EAD3; color:#C9982E;"
				>1</div>
				<h3 class="mt-3 text-base font-bold" style="color:#221B10; font-family:'Manrope',sans-serif;">Choose a photo</h3>
				<p class="mt-1 text-[15px]" style="color:#4A4234;">
					Select any JPG, PNG, WebP, or an iPhone HEIC photo &mdash; decoded
					right in your browser.
				</p>
			</div>
			<div class="rounded-xl p-5 shadow-sm" style="background:#FAF8F3; border:1px solid #EAE4D6;">
				<div
					class="flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold"
					style="background:#F4EAD3; color:#C9982E;"
				>2</div>
				<h3 class="mt-3 text-base font-bold" style="color:#221B10; font-family:'Manrope',sans-serif;">Pick duration &amp; motion</h3>
				<p class="mt-1 text-[15px]" style="color:#4A4234;">
					1 to 30 seconds, exported as MP4 (H.264) or WebM (VP8), with an
					optional Ken Burns zoom or pan.
				</p>
			</div>
			<div class="rounded-xl p-5 shadow-sm" style="background:#FAF8F3; border:1px solid #EAE4D6;">
				<div
					class="flex h-9 w-9 items-center justify-center rounded-full text-sm font-bold"
					style="background:#F4EAD3; color:#C9982E;"
				>3</div>
				<h3 class="mt-3 text-base font-bold" style="color:#221B10; font-family:'Manrope',sans-serif;">Download the clip</h3>
				<p class="mt-1 text-[15px]" style="color:#4A4234;">
					ffmpeg.wasm renders the video locally, then you download it directly.
					Nothing ever touches a server.
				</p>
			</div>
		</div>
	</section>

	{/* SNAKE BOREDOM-FILLER — surfaced prominently because encoding is a slow
	    task. Canonical self-contained block; only the wrapper card classes were
	    adjusted to the tool's warm card style. */}
	<section class="mx-auto mt-14 max-w-[820px]">
		<details id="snake-details" class="rounded-2xl border border-[#eae4d6] bg-[#faf8f3] p-5">
			<summary class="cursor-pointer select-none font-[Sora] text-lg font-bold text-[#221b10]">This can take a moment — play a round of Snake while you wait</summary>
			<div class="mt-4 flex flex-col items-center gap-3">
				<canvas id="snake-canvas" width="320" height="320" class="rounded-lg border border-[#eae4d6] bg-white" style="touch-action:none"></canvas>
				<div class="flex items-center gap-4 text-sm text-[#4a4234]">
					<span>Score: <b id="snake-score">0</b></span>
					<button id="snake-restart" class="rounded-lg bg-[#c9982e] px-4 py-2 font-semibold text-white transition hover:bg-[#b8860b]">Restart</button>
				</div>
				<p class="text-xs text-[#8a7e68]">Arrow keys / WASD, or swipe on mobile.</p>
			</div>
		</details>
	</section>

	<script>
		(() => {
			const cv = document.getElementById('snake-canvas'); if (!cv) return;
			const ctx = cv.getContext('2d'); const G = 16, N = 20; let snake, dir, food, score, alive, loop;
			const scoreEl = document.getElementById('snake-score');
			function reset(){ snake=[{x:10,y:10}]; dir={x:0,y:0}; food=rndFood(); score=0; alive=true; if(scoreEl)scoreEl.textContent='0'; }
			function rndFood(){ return {x:Math.floor(Math.random()*N), y:Math.floor(Math.random()*N)}; }
			function step(){
				if(!alive) return;
				if(dir.x===0&&dir.y===0){ draw(); return; }
				const h={x:snake[0].x+dir.x, y:snake[0].y+dir.y};
				if(h.x<0||h.y<0||h.x>=N||h.y>=N||snake.some(s=>s.x===h.x&&s.y===h.y)){ alive=false; draw(); return; }
				snake.unshift(h);
				if(h.x===food.x&&h.y===food.y){ score++; if(scoreEl)scoreEl.textContent=String(score); food=rndFood(); } else snake.pop();
				draw();
			}
			function draw(){
				ctx.fillStyle='#ffffff'; ctx.fillRect(0,0,cv.width,cv.height);
				ctx.fillStyle='#c9982e'; snake.forEach(s=>ctx.fillRect(s.x*G+1,s.y*G+1,G-2,G-2));
				ctx.fillStyle='#221b10'; ctx.fillRect(food.x*G+3,food.y*G+3,G-6,G-6);
				if(!alive){ ctx.fillStyle='rgba(34,27,16,0.72)'; ctx.fillRect(0,0,cv.width,cv.height); ctx.fillStyle='#fff'; ctx.font='bold 20px Sora, sans-serif'; ctx.textAlign='center'; ctx.fillText('Game Over — Restart', cv.width/2, cv.height/2); }
			}
			function turn(x,y){ if((x!==0&&dir.x===0)||(y!==0&&dir.y===0)) dir={x,y}; }
			window.addEventListener('keydown', e=>{ const k=e.key.toLowerCase(); if(['arrowup','w'].includes(k))turn(0,-1); else if(['arrowdown','s'].includes(k))turn(0,1); else if(['arrowleft','a'].includes(k))turn(-1,0); else if(['arrowright','d'].includes(k))turn(1,0); else return; e.preventDefault(); }, {passive:false});
			let tx,ty; cv.addEventListener('touchstart',e=>{tx=e.touches[0].clientX;ty=e.touches[0].clientY;},{passive:true});
			cv.addEventListener('touchend',e=>{ const dx=e.changedTouches[0].clientX-tx, dy=e.changedTouches[0].clientY-ty; if(Math.abs(dx)>Math.abs(dy)) turn(dx>0?1:-1,0); else turn(0,dy>0?1:-1); },{passive:true});
			document.getElementById('snake-restart')?.addEventListener('click', reset);
			reset(); loop=setInterval(step, 110);
		})();
	</script>

	<script type="module">
		// NOTE: user-controlled strings (filenames, error text) are rendered
		// only via textContent below, never innerHTML, so no HTML-escaping is
		// needed on this page. The shared src/lib/escapeHtml.ts helper remains
		// the canonical utility for any future HTML-sink path in this family.

		const imageInput = document.getElementById('image-input');
		const dropZone = document.getElementById('drop-zone');
		const previewWrap = document.getElementById('preview-wrap');
		const previewImg = document.getElementById('preview-img');
		const durationInput = document.getElementById('duration-input');
		const durationRange = document.getElementById('duration-range');
		const formatSelect = document.getElementById('format-select');
		const motionGrid = document.getElementById('motion-grid');
		const motionValue = document.getElementById('motion-value');
		const generateBtn = document.getElementById('generate-btn');
		const statusWrap = document.getElementById('status-wrap');
		const statusText = document.getElementById('status-text');
		const statusPercent = document.getElementById('status-percent');
		const progressBar = document.getElementById('progress-bar');
		const errorBox = document.getElementById('error-box');
		const resultWrap = document.getElementById('result-wrap');
		const resultVideo = document.getElementById('result-video');
		const downloadLink = document.getElementById('download-link');

		let selectedFile = null;
		// When the selected file is HEIC/HEIF, this holds the decoded PNG blob
		// (browsers and ffmpeg.wasm's default core can't read HEIC directly).
		let decodedBlob = null;
		let ffmpeg = null;
		let lastObjectUrl = null;
		let lastPreviewUrl = null;

		const MOTIONS = ['none', 'zoom-in', 'zoom-out', 'pan-left', 'pan-right'];

		// Ken Burns direction picker (segmented buttons -> hidden input).
		motionGrid.addEventListener('click', (e) => {
			const btn = e.target.closest('.motion-opt');
			if (!btn) return;
			const value = btn.getAttribute('data-motion');
			if (!MOTIONS.includes(value)) return;
			motionValue.value = value;
			motionGrid.querySelectorAll('.motion-opt').forEach((el) => {
				const active = el === btn;
				el.setAttribute('aria-pressed', active ? 'true' : 'false');
				el.style.border = active ? '1px solid #C9982E' : '1px solid #EAE4D6';
				el.style.background = active ? '#F4EAD3' : '#FFFFFF';
				el.style.color = active ? '#221B10' : '#4A4234';
			});
		});

		function isHeicFile(file) {
			return (
				/\.(heic|heif)$/i.test(file.name) ||
				file.type === 'image/heic' ||
				file.type === 'image/heif'
			);
		}

		async function decodeHeicToPng(file) {
			const libheif = await import('libheif-js/wasm-bundle');
			const decoder = new libheif.HeifDecoder();
			const arrayBuffer = await file.arrayBuffer();
			const images = decoder.decode(arrayBuffer);
			if (!images || images.length === 0) {
				throw new Error('no image found in this HEIC file');
			}
			const heicImage = images[0];
			const width = heicImage.get_width();
			const height = heicImage.get_height();
			const canvas = document.createElement('canvas');
			canvas.width = width;
			canvas.height = height;
			const ctx = canvas.getContext('2d');
			if (!ctx) throw new Error('canvas not supported');
			const imageData = ctx.createImageData(width, height);
			await new Promise((res, rej) => {
				heicImage.display(imageData, (displayData) => {
					if (!displayData) {
						rej(new Error('HEIF pixel decode failed'));
						return;
					}
					res(undefined);
				});
			});
			ctx.putImageData(imageData, 0, 0);
			const blob = await new Promise((res) => canvas.toBlob(res, 'image/png'));
			if (!blob) throw new Error('could not encode decoded HEIC as PNG');
			return blob;
		}

		// Keep the number input and range slider in sync + clamp on the number field.
		durationInput.addEventListener('input', () => {
			durationRange.value = durationInput.value;
		});
		durationRange.addEventListener('input', () => {
			durationInput.value = durationRange.value;
		});

		dropZone.addEventListener('dragover', (e) => {
			e.preventDefault();
			dropZone.style.borderColor = '#C9982E';
		});
		dropZone.addEventListener('dragleave', () => {
			dropZone.style.borderColor = '#EAE4D6';
		});
		dropZone.addEventListener('drop', (e) => {
			e.preventDefault();
			dropZone.style.borderColor = '#EAE4D6';
			const file = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
			if (file) {
				const dt = new DataTransfer();
				dt.items.add(file);
				imageInput.files = dt.files;
				imageInput.dispatchEvent(new Event('change'));
			}
		});

		imageInput.addEventListener('change', async () => {
			const file = imageInput.files && imageInput.files[0];
			selectedFile = file || null;
			decodedBlob = null;
			hideError();
			hideResult();

			if (!file) {
				previewWrap.classList.add('hidden');
				return;
			}

			if (isHeicFile(file)) {
				try {
					previewWrap.classList.add('hidden');
					setStatus('Decoding HEIC…', 0);
					decodedBlob = await decodeHeicToPng(file);
					clearStatus();
				} catch (err) {
					clearStatus();
					showError(
						`Could not decode this HEIC file (${
							err instanceof Error ? err.message : 'unsupported variant'
						}).`,
					);
					return;
				}
			}

			if (lastPreviewUrl) URL.revokeObjectURL(lastPreviewUrl);
			lastPreviewUrl = URL.createObjectURL(decodedBlob || file);
			previewImg.src = lastPreviewUrl;
			previewWrap.classList.remove('hidden');
		});

		function showError(message) {
			// message may embed a user-controlled filename/error string.
			// Assigning via textContent (never innerHTML) renders any HTML in a
			// malicious filename inert — there is no XSS sink here at all, so no
			// pre-escaping is needed (that would double-encode and show literal
			// entities). escapeHtml is retained in the codebase for any future
			// path that genuinely needs an HTML sink.
			errorBox.textContent = message;
			errorBox.classList.remove('hidden');
		}

		function hideError() {
			errorBox.classList.add('hidden');
			errorBox.textContent = '';
		}

		function hideResult() {
			resultWrap.classList.add('hidden');
			if (lastObjectUrl) {
				URL.revokeObjectURL(lastObjectUrl);
				lastObjectUrl = null;
			}
		}

		function setStatus(text, percent) {
			statusWrap.classList.remove('hidden');
			statusText.textContent = text;
			if (typeof percent === 'number' && !Number.isNaN(percent)) {
				const clamped = Math.max(0, Math.min(100, Math.round(percent)));
				statusPercent.textContent = `${clamped}%`;
				progressBar.style.width = `${clamped}%`;
			} else {
				statusPercent.textContent = '';
				progressBar.style.width = '0%';
			}
		}

		function clearStatus() {
			statusWrap.classList.add('hidden');
			progressBar.style.width = '0%';
			statusPercent.textContent = '';
		}

		function setBusy(busy) {
			generateBtn.disabled = busy;
			generateBtn.textContent = busy ? 'Generating…' : 'Generate Video';
		}

		async function getFFmpeg() {
			if (ffmpeg) return ffmpeg;

			setStatus('Loading engine…');

			// Loaded lazily (only when the user clicks Generate) so the
			// ffmpeg.wasm engine is never downloaded on page load.
			const { FFmpeg } = await import('@ffmpeg/ffmpeg');
			const { toBlobURL } = await import('@ffmpeg/util');

			const instance = new FFmpeg();

			instance.on('progress', ({ progress }) => {
				if (typeof progress === 'number' && !Number.isNaN(progress)) {
					setStatus('Rendering video…', progress * 100);
				}
			});

			const baseURL = 'https://unpkg.com/@ffmpeg/core@0.12.10/dist/esm';

			await instance.load({
				coreURL: await toBlobURL(
					`${baseURL}/ffmpeg-core.js`,
					'text/javascript'
				),
				wasmURL: await toBlobURL(
					`${baseURL}/ffmpeg-core.wasm`,
					'application/wasm'
				),
			});

			ffmpeg = instance;
			return ffmpeg;
		}

		// A crashed wasm run (e.g. an out-of-bounds memory access) permanently
		// poisons the ffmpeg instance — every later exec on it fails instantly.
		// Terminate and drop it so the next attempt loads a fresh engine.
		function resetEngine() {
			if (ffmpeg) {
				try {
					ffmpeg.terminate();
				} catch {
					// already dead — nothing to do
				}
				ffmpeg = null;
			}
		}

		function extForInput(file) {
			const name = file.name || '';
			const match = /\.([a-zA-Z0-9]+)$/.exec(name);
			if (match) return match[1].toLowerCase();
			if (file.type === 'image/png') return 'png';
			if (file.type === 'image/webp') return 'webp';
			return 'jpg';
		}

		async function loadBitmap(blob) {
			if ('createImageBitmap' in window) {
				try {
					return await createImageBitmap(blob);
				} catch {
					// fall through to <img> decode
				}
			}
			return await new Promise((res, rej) => {
				const img = new Image();
				const u = URL.createObjectURL(blob);
				img.onload = () => res(img);
				img.onerror = () => {
					URL.revokeObjectURL(u);
					rej(new Error('could not decode image'));
				};
				img.src = u;
			});
		}

		// Ken Burns: render each output frame on a canvas with a slowly
		// drifting crop window (subpixel-smooth, unlike ffmpeg's zoompan),
		// then hand the JPEG frames to ffmpeg as an image sequence.
		const MOTION_FPS = 24;
		const MOTION_MAX_EDGE = 1080;

		async function renderMotionFrames(engine, sourceBlob, duration, motion) {
			const bmp = await loadBitmap(sourceBlob);
			const sw = bmp.width || bmp.naturalWidth;
			const sh = bmp.height || bmp.naturalHeight;
			const scale = Math.min(1, MOTION_MAX_EDGE / Math.max(sw, sh));
			const W = Math.max(2, Math.round((sw * scale) / 2) * 2);
			const H = Math.max(2, Math.round((sh * scale) / 2) * 2);
			const total = Math.max(2, Math.min(Math.round(duration * MOTION_FPS), 720));

			const canvas = document.createElement('canvas');
			canvas.width = W;
			canvas.height = H;
			const ctx = canvas.getContext('2d');
			if (!ctx) throw new Error('canvas not supported');
			ctx.imageSmoothingEnabled = true;
			ctx.imageSmoothingQuality = 'high';

			// Cover-rect of the source matching the output aspect ratio.
			const outAspect = W / H;
			let cw = sw;
			let ch = sw / outAspect;
			if (ch > sh) {
				ch = sh;
				cw = sh * outAspect;
			}
			const coverX = (sw - cw) / 2;
			const coverY = (sh - ch) / 2;

			const isZoom = motion === 'zoom-in' || motion === 'zoom-out';
			const isPan = motion === 'pan-left' || motion === 'pan-right';

			const names = [];
			for (let i = 0; i < total; i++) {
				const t = total <= 1 ? 0 : i / (total - 1);
				let z, sx, sy;
				if (isZoom) {
					// zoom-in: 1.0 -> 1.12; zoom-out: 1.12 -> 1.0 (reverse t).
					const zt = motion === 'zoom-in' ? t : 1 - t;
					z = 1 + 0.12 * zt;
					sx = coverX + (cw - cw / z) / 2;
					sy = coverY + (ch - ch / z) / 2;
				} else if (isPan) {
					// fixed 1.1x zoom, crop window drifts horizontally.
					z = 1.1;
					const pt = motion === 'pan-right' ? t : 1 - t;
					sx = coverX + (cw - cw / z) * pt;
					sy = coverY + (ch - ch / z) / 2;
				} else {
					z = 1;
					sx = coverX;
					sy = coverY;
				}
				ctx.clearRect(0, 0, W, H);
				ctx.drawImage(bmp, sx, sy, cw / z, ch / z, 0, 0, W, H);
				const frameBlob = await new Promise((res) =>
					canvas.toBlob(res, 'image/jpeg', 0.82)
				);
				if (!frameBlob) throw new Error('could not render motion frame');
				const name = `f${String(i).padStart(5, '0')}.jpg`;
				await engine.writeFile(
					name,
					new Uint8Array(await frameBlob.arrayBuffer())
				);
				names.push(name);
				if (i % 6 === 0 || i === total - 1) {
					setStatus('Preparing motion frames…', ((i + 1) / total) * 100);
				}
			}
			if (typeof bmp.close === 'function') bmp.close();
			return names;
		}

		async function generateVideo() {
			hideError();
			hideResult();

			if (!selectedFile) {
				showError('Please choose an image first.');
				return;
			}

			let duration = parseInt(durationInput.value, 10);
			if (Number.isNaN(duration) || duration < 1) duration = 1;
			if (duration > 30) duration = 30;
			durationInput.value = String(duration);
			durationRange.value = String(duration);

			const format = formatSelect.value === 'webm' ? 'webm' : 'mp4';
			const motion = MOTIONS.includes(motionValue.value) ? motionValue.value : 'none';
			const inputExt = decodedBlob ? 'png' : extForInput(selectedFile);
			const inputName = `input.${inputExt}`;
			const outputName = format === 'mp4' ? 'output.mp4' : 'output.webm';

			setBusy(true);

			let engine;
			try {
				engine = await getFFmpeg();
			} catch (err) {
				setBusy(false);
				clearStatus();
				showError(
					'Could not load the video engine. Check your connection and try again.'
				);
				console.error(err);
				return;
			}

			let crashed = false;
			let frameNames = [];
			try {
				const { fetchFile } = await import('@ffmpeg/util');

				setStatus('Preparing image…', 0);

				let args;
				if (motion === 'none') {
					await engine.writeFile(
						inputName,
						await fetchFile(decodedBlob || selectedFile),
					);

					const scaleFilter = 'scale=trunc(iw/2)*2:trunc(ih/2)*2';
					if (format === 'mp4') {
						args = [
							'-loop', '1',
							'-i', inputName,
							'-c:v', 'libx264',
							'-t', String(duration),
							'-pix_fmt', 'yuv420p',
							'-vf', scaleFilter,
							outputName,
						];
					} else {
						// WebM is encoded as VP8 (libvpx), NOT VP9: libvpx-vp9 in
						// @ffmpeg/core 0.12.10 reliably throws "RuntimeError: memory
						// access out of bounds" (wasm memory-growth bug) even on a
						// fresh instance with -deadline realtime — confirmed by
						// direct probing against the deployed bundle. VP8 encodes
						// the same WebM container reliably and fast.
						args = [
							'-loop', '1',
							'-i', inputName,
							'-c:v', 'libvpx',
							'-t', String(duration),
							'-pix_fmt', 'yuv420p',
							'-vf', scaleFilter,
							'-b:v', '2M',
							'-deadline', 'realtime',
							'-cpu-used', '8',
							outputName,
						];
					}
				} else {
					frameNames = await renderMotionFrames(
						engine,
						decodedBlob || selectedFile,
						duration,
						motion
					);
					setStatus('Rendering video…', 0);
					if (format === 'mp4') {
						args = [
							'-framerate', String(MOTION_FPS),
							'-i', 'f%05d.jpg',
							'-c:v', 'libx264',
							'-preset', 'veryfast',
							'-pix_fmt', 'yuv420p',
							outputName,
						];
					} else {
						args = [
							'-framerate', String(MOTION_FPS),
							'-i', 'f%05d.jpg',
							'-c:v', 'libvpx',
							'-b:v', '2M',
							'-deadline', 'realtime',
							'-cpu-used', '8',
							'-pix_fmt', 'yuv420p',
							outputName,
						];
					}
				}

				await engine.exec(args);

				const data = await engine.readFile(outputName);
				// A poisoned/failed exec can return an empty file instead of
				// throwing. Treat a zero-byte output as a hard failure so we
				// surface a clean error instead of handing back a broken blob.
				if (!data || data.length === 0) {
					throw new Error('encoder produced an empty file');
				}
				const mime = format === 'mp4' ? 'video/mp4' : 'video/webm';
				const blob = new Blob([data.buffer], { type: mime });
				const url = URL.createObjectURL(blob);
				lastObjectUrl = url;

				resultVideo.src = url;
				downloadLink.href = url;
				downloadLink.download = `stillmotion.${format}`;
				resultWrap.classList.remove('hidden');

				setStatus('Done', 100);
				setTimeout(clearStatus, 1500);
			} catch (err) {
				crashed = true;
				clearStatus();
				const fmtLabel = format === 'webm' ? 'WebM' : 'MP4';
				showError(
					`Could not render the ${fmtLabel} clip on this device. The engine has been reset — try again, pick a smaller image, or switch the output format.`
				);
				console.error(err);
				// A wasm crash leaves the engine unusable; rebuild it next run.
				resetEngine();
			} finally {
				if (!crashed) {
					// Clean up virtual FS files after each run so repeated
					// conversions don't leak memory inside ffmpeg.wasm.
					if (motion === 'none') {
						try {
							await engine.deleteFile(inputName);
						} catch {
							// ignore — file may not have been written
						}
					}
					for (const name of frameNames) {
						try {
							await engine.deleteFile(name);
						} catch {
							// ignore
						}
					}
					try {
						await engine.deleteFile(outputName);
					} catch {
						// ignore — file may not have been produced
					}
				}
				setBusy(false);
			}
		}

		generateBtn.addEventListener('click', generateVideo);

		// Deterministic hooks for automated playtesting (kept in prod: tiny,
		// read-only, and make live QA of the real encode path possible).
		window.__sm = {
			setMotion: (m) => {
				const btn = motionGrid.querySelector(`.motion-opt[data-motion="${m}"]`);
				if (btn) btn.click();
				return motionValue.value;
			},
			getMotion: () => motionValue.value,
			hasResult: () => !resultWrap.classList.contains('hidden'),
			resultSrc: () => resultVideo.currentSrc || resultVideo.src || '',
			errorText: () =>
				errorBox.classList.contains('hidden') ? '' : errorBox.textContent,
		};
	</script>
</Layout>
